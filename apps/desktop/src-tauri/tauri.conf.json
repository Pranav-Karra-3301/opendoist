{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OpenTask",
  "version": "0.3.0",
  "identifier": "com.opentask.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @opentask/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @opentask/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "OpenTask",
        "width": 1040,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "visible": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#fcfcf8"
      },
      {
        "label": "quickadd",
        "url": "quickadd.html",
        "width": 660,
        "height": 460,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCODA3NzJEMkFDRDA4MkQKUldRdENNMHFMWGVBaThQa2F0Wkx6SHhhbnRHZGZQWUdlajVva3FTaVV3czJLQ0xzbUF2dDEwZUMK",
      "endpoints": [
        "https://github.com/Pranav-Karra-3301/opentask/releases/download/desktop-latest/latest.json"
      ]
    }
  }
}
