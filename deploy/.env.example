# OpenTask deployment configuration.
# Copy to `.env` next to docker-compose.yml before `docker compose up -d`.
# Every variable is optional — the image ships working defaults. Full list: docs/configuration.md.

# Image tag to run: latest | nightly | X.Y | X.Y.Z
OPENTASK_VERSION=latest

# Absolute public origin, e.g. https://todo.example.com (recommended behind a reverse proxy).
# Enables correct Web Push, iCal feed, and OIDC callback URLs. Leave blank for plain localhost.
OPENTASK_PUBLIC_URL=

# Re-open self-service registration after the first account exists (default: closed).
# OPENTASK_ALLOW_REGISTRATION=true

# Log level: trace | debug | info | warn | error
OPENTASK_LOG_LEVEL=info
